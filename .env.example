# ============================================================================
#  Скопируй этот файл в .env и заполни. (на Railway — задай те же
#  переменные во вкладке Variables, файл .env туда загружать не надо)
#  Где что брать — пошагово в docs/01-setup.md
# ============================================================================

# ── ОБЯЗАТЕЛЬНО (без этого бот не запустится) ───────────────────────────────

# 1. Токен Telegram-бота — получишь у @BotFather (см. docs/01-setup.md)
TELEGRAM_BOT_TOKEN=

# 2. Твой личный chat_id — узнаешь у @userinfobot (бот отвечает только тебе)
TELEGRAM_CHAT_ID=

# 3. Ключ Claude API — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# 4. Supabase — Project Settings → API.
#    SUPABASE_KEY = ключ service_role (он секретный, живёт только на сервере)
SUPABASE_URL=
SUPABASE_KEY=

# ── РАСПИСАНИЕ (можно не трогать) ────────────────────────────────────────────
TIMEZONE=Europe/Kyiv     # напр. America/Los_Angeles, Europe/Moscow
MORNING_HOUR=8           # час утреннего чекина
EVENING_HOUR=21          # час вечернего чекина

# ── ОПЦИОНАЛЬНЫЕ МОДУЛИ (по умолчанию выкл; включай по урокам в docs/) ───────
ENABLE_CYCLE=false           # день цикла и энергия по фазам — docs/03-add-cycle.md
ENABLE_GMAIL=false           # чтение почты — docs/04-add-gmail.md
ENABLE_GCAL=false            # календарь — docs/05-add-calendar.md
ENABLE_REMINDERS=false       # напоминания «напомни через...» — docs/06-add-reminders.md
ENABLE_WEEKLY_REVIEW=false   # недельный обзор по воскресеньям — docs/06-add-reminders.md

# ── КЛЮЧИ ДЛЯ ОПЦИЙ (заполняй, только когда включаешь модуль) ────────────────

# Голосовые сообщения (Whisper). Нужен ключ OpenAI — platform.openai.com
OPENAI_API_KEY=

# Google (для почты и календаря). Как получить — docs/04-add-gmail.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Адрес твоего бота на Railway + /google/callback
# Пример: https://your-app.up.railway.app/google/callback
GOOGLE_REDIRECT_URI=
